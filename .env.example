# Canonical public URL (Open Graph, JSON-LD, sitemap). Production: https://lcguns.com
# NEXT_PUBLIC_SITE_URL=https://lcguns.com

# Resend (contact form) — https://resend.com/docs/send-with-nextjs
# Never commit real keys. Copy to `.env.local` for development.
# On Vercel: Project → Settings → Environment Variables → add for Production (and Preview if needed), then redeploy.
RESEND_API_KEY=
# Verified sender in Resend, e.g. "Lowcountry Guns <noreply@lcguns.com>"
RESEND_FROM_EMAIL=
# Some setups use this name instead of RESEND_FROM_EMAIL (either is accepted by the app):
# RESEND_FROM=
# Inbox that receives website contact submissions
CONTACT_TO_EMAIL=aj@lcguns.com

# Optional: KV / Upstash (also used for MOTD). When set, contact API rate-limits by IP.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
