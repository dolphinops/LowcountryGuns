# Canonical public URL (Open Graph, JSON-LD, sitemap). Production: https://lcguns.com
# NEXT_PUBLIC_SITE_URL=https://lcguns.com

# Resend (contact form) — https://resend.com/api-keys
# Use an API key from the Resend project where lcguns.com is verified.
# Never commit real keys. For local dev: copy this file to `.env.local` and paste your key there only.
# Production: Vercel → Settings → Environment Variables → RESEND_API_KEY → redeploy.
RESEND_API_KEY=
# Optional: override default sender "Lowcountry Guns <noreply@lcguns.com>" (must be verified in Resend).
# Do NOT use onboarding@resend.dev in production — Resend only allows test sends to your own inbox.
# RESEND_FROM_EMAIL=
# Some setups use this name instead of RESEND_FROM_EMAIL (either is accepted by the app):
# RESEND_FROM=
# Optional: override default inbox aj@lcguns.com for contact form deliveries.
# CONTACT_TO_EMAIL=aj@lcguns.com

# Optional: KV / Upstash (also used for MOTD). When set, contact API rate-limits by IP.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
