# Resend (contact form) — https://resend.com/docs/dashboard/receiving/introduction
# Never commit real keys. Copy to `.env.local` for development.
RESEND_API_KEY=
# Verified sender, e.g. "Lowcountry Guns <contact@yourdomain.com>" or Resend onboarding domain for testing.
RESEND_FROM_EMAIL=
# Inbox that receives website contact submissions
CONTACT_TO_EMAIL=aj@lcguns.com

# Optional: KV / Upstash (also used for MOTD). When set, contact API rate-limits by IP.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
